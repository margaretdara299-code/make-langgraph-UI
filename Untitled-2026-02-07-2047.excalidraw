      "updated": 1775648411149,
      "link": null,
      "locked": false,
      "text": "Database tables used\n\n1. RCM_CASE\n- RCM_CASE_ID\n- CLAIM_ID\n- STATUS\n\n2. RCM_CASE_FACT\n- FACT_KEY\n- FACT_VALUE_STR\n- DOCUMENT_STATUS\n- DENIAL_REASON\n- APPEAL_DEADLINE\n- PATIENT_AGE",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
