      "updated": 1775512822704,
      "link": null,
      "locked": false,
      "text": "if case_age >= 90:\n    risk_level = \"CRITICAL\"\nelif case_age >= 60:\n    risk_level = \"HIGH\"\nelif case_age >= 30:\n    risk_level = \"MEDIUM\"\nelse:\n    risk_level = \"LOW\"",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "lIpR-RhBfO1A_om-KhUvd",
      "originalText": "if case_age >= 90:\n    risk_level = \"CRITICAL\"\nelif case_age >= 60:\n    risk_level = \"HIGH\"\nelif case_age >= 30:\n    risk_level = \"MEDIUM\"\nelse:\n    risk_level = \"LOW\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
