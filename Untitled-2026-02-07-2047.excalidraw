      "text": "1.Query document review status\n\n2.SELECT FACT_VALUE_STR FROM\nRCM_CASE_FACT WHERE RCM_CASE_ID = :case_id\nAND FACT_KEY = 'REVIEW_REQUIRED'\n\n3.review_required = fact_row[\"FACT_VALUE_STR\"]\n== \"TRUE\" if fact_row else False",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "ePRniz7YJ2BJRD0qFm0wm",
      "originalText": "1.Query document review status\n\n2.SELECT FACT_VALUE_STR FROM RCM_CASE_FACT WHERE RCM_CASE_ID = :case_id AND FACT_KEY = 'REVIEW_REQUIRED'\n\n3.review_required = fact_row[\"FACT_VALUE_STR\"] == \"TRUE\" if fact_row else False",
      "autoResize": true,
      "lineHeight": 1.25
    },
