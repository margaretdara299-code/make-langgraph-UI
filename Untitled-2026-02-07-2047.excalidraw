      "text": "Decision Processing\n\nRules:\n1. docs incomplete → request docs\n2. CO-97 + age>=65 → Medicare review\n3. CO-96/CO-97 → standard appeal\n4. else → manual review",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 19,
      "originalText": "Decision Processing\n\nRules:\n1. docs incomplete → request docs\n2. CO-97 + age>=65 → Medicare review\n3. CO-96/CO-97 → standard appeal\n4. else → manual review",
      "lineHeight": 1.25,
      "containerId": null,
      "index": "b1X",
      "autoResize": true
    },
